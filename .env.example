# ==============================================
# Roneira AI HIFI — Environment Variables
# Copy this to .env.local and fill in your values
# ==============================================

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ML_BACKEND_URL=http://localhost:8000

# Alpha Vantage — Stock data & fundamentals (free: 25 req/day)
ALPHA_VANTAGE_API_KEY=

# Finnhub — Real-time quotes & company data (free: 60 calls/min)
FINNHUB_API_KEY=

# NewsAPI — Market news (free: 100 req/day)
NEWS_API_KEY=

# Hugging Face — Sentiment analysis models
HUGGING_FACE_API_KEY=

# Twelve Data — Additional market data source
TWELVE_DATA_API_KEY=

# Upstash Redis — Distributed caching
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# Admin seed script
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_FULL_NAME=
ADMIN_USERNAME=

# ML artifact loading
ML_MODEL_DIR=./artifacts/generated
